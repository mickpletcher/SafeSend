# SafeSend Webhook Receiver - Environment Configuration
# Copy this file to .env and fill in your values

# ------------------------------------------------------------------
# Webhook Security
# ------------------------------------------------------------------
# Shared secret for validating incoming SafeSend webhooks.
# Set this same value in SafeSend Developer Section as the API key.
# Leave blank to skip validation (development only).
WEBHOOK_SECRET=your_shared_secret_here

# ------------------------------------------------------------------
# Document Storage
# ------------------------------------------------------------------
# Where downloaded documents will be saved.
# Windows example:  DOWNLOAD_BASE_PATH=C:\SafeSendDocuments
# UNC example:      DOWNLOAD_BASE_PATH=\\fileserver\safesend\documents
# Linux/Azure:      DOWNLOAD_BASE_PATH=/mnt/safesend/documents
DOWNLOAD_BASE_PATH=downloads

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ------------------------------------------------------------------
# Optional Integrations
# ------------------------------------------------------------------
# Microsoft Teams incoming webhook URL for event notifications
TEAMS_WEBHOOK_URL=

# Azure Service Bus (replace in-memory queue for production)
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_NAME=safesend-events
